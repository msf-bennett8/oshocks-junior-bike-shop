{
  "name": "oshocks-frontend",
  "version": "1.0.0",
  "private": true,
  "homepage": "/",
  "description": "Oshoks Junior Bike Shop - Frontend",
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "axios": "^1.12.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "laravel-echo": "^2.3.4",
    "lucide-react": "^0.545.0",
    "pusher-js": "^8.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^4.12.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "recharts": "^2.12.7",
    "redux": "^5.0.1",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "happy-dom": "^17.6.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.18",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^0.21.2",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^3.2.6"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "react-hooks/exhaustive-deps": "warn",
      "no-restricted-globals": [
        "error",
        "event",
        "fdescribe",
        "fit"
      ]
    },
    "overrides": [
      {
        "files": [
          "**/service-worker.js",
          "**/service-worker.ts"
        ],
        "env": {
          "serviceworker": true
        },
        "globals": {
          "clients": "readonly"
        },
        "rules": {
          "no-restricted-globals": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
