{
  "name": "oshocks-frontend",
  "version": "1.0.0",
  "private": true,
  "homepage": "/",
  "description": "Oshoks Junior Bike Shop - Frontend",
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "axios": "^1.12.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "laravel-echo": "^2.3.4",
    "lucide-react": "^0.545.0",
    "pusher-js": "^8.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^4.12.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "recharts": "^2.12.7",
    "redux": "^5.0.1",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react-scripts": "^5.0.1",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.18",
    "workbox-cli": "^7.4.1",
    "workbox-webpack-plugin": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && npm run build:sw",
    "build:sw": "workbox injectManifest workbox-config.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "react-hooks/exhaustive-deps": "warn",
      "no-restricted-globals": [
        "error",
        "event",
        "fdescribe",
        "fit"
      ]
    },
    "overrides": [
      {
        "files": [
          "**/service-worker.js",
          "**/service-worker.ts"
        ],
        "env": {
          "serviceworker": true
        },
        "globals": {
          "clients": "readonly"
        },
        "rules": {
          "no-restricted-globals": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
