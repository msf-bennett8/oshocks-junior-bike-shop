#!/bin/bash

# Reverb WebSocket Server Control Script
PIDFILE="/tmp/reverb-oshocks.pid"
LOGFILE="/tmp/reverb-oshocks.log"
PROJECT_DIR="$HOME/studio.dev/oshocks/backend"

C_RESET='\033[0m'
C_RED='\033[0;31m'
C_GREEN='\033[0;32m'
C_MAGENTA='\033[0;35m'
C_CYAN='\033[0;36m'

start_reverb() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo -e "[${C_MAGENTA}REVERB${C_RESET}] ${C_GREEN}Already running (PID: $(cat $PIDFILE))${C_RESET}"
        exit 1
    fi
    cd "$PROJECT_DIR" || exit 1
    nohup php artisan reverb:start --host=0.0.0.0 --port=8080 > "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    echo -e "[${C_GREEN}OK${C_RESET}] ${C_GREEN}Reverb started on 0.0.0.0:8080 (PID: $!)${C_RESET}"
}

stop_reverb() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID" 2>/dev/null
            sleep 1
            kill -0 "$PID" 2>/dev/null && kill -9 "$PID" 2>/dev/null
            echo -e "[${C_GREEN}OK${C_RESET}] ${C_GREEN}Reverb stopped${C_RESET}"
        else
            echo -e "[${C_MAGENTA}REVERB${C_RESET}] ${C_RED}Not running (stale PID file)${C_RESET}"
        fi
        rm -f "$PIDFILE"
    else
        echo -e "[${C_MAGENTA}REVERB${C_RESET}] ${C_RED}Not running${C_RESET}"
    fi
}

status_reverb() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo -e "[${C_MAGENTA}REVERB${C_RESET}]  ${C_GREEN}RUNNING${C_RESET} (PID: $(cat $PIDFILE), Port: ${C_CYAN}8080${C_RESET})"
    else
        echo -e "[${C_MAGENTA}REVERB${C_RESET}]  ${C_RED}STOPPED${C_RESET}"
        [ -f "$PIDFILE" ] && rm -f "$PIDFILE"
    fi
}

clear_reverb() {
    rm -f "$LOGFILE"
    echo -e "[${C_GREEN}OK${C_RESET}] ${C_GREEN}Reverb logs cleared${C_RESET}"
}

logs_reverb() {
    if [ -f "$LOGFILE" ]; then
        tail -f "$LOGFILE"
    else
        echo -e "[${C_MAGENTA}REVERB${C_RESET}] ${C_RED}No log file found. Start Reverb first.${C_RESET}"
    fi
}

case "$1" in
    start)   start_reverb ;;
    stop)    stop_reverb ;;
    restart) stop_reverb; sleep 1; start_reverb ;;
    status)  status_reverb ;;
    clear)   clear_reverb ;;
    logs)    logs_reverb ;;
    *)       echo -e "${C_RED}Usage: $0 {start|stop|restart|status|clear|logs}${C_RESET}"; exit 1 ;;
esac
